{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/founder_questions_surface.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/scripts/session_knowledge_inject.sh\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "GUARD=\"${CLAUDE_PROJECT_DIR:-.}/scripts/hook_pretool_guard.py\"; if [ -f \"$GUARD\" ]; then python3 \"$GUARD\"; else exit 0; fi"
          }
        ]
      }
    ]
  }
}
